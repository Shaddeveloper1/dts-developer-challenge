{
  "name": "hmcts-task-manager-frontend",
  "version": "1.0.0",
  "description": "HMCTS Task Manager Frontend - React/TypeScript UI for caseworker task management",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
