{
  "name": "hmcts-task-manager-backend",
  "version": "1.0.0",
  "description": "HMCTS Task Manager API - Backend service for caseworker task management",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
